  "misconceptions": [
    {"concept_id": "newtons-laws", "misconception": "Students often think that a force is required to keep an object in motion (Aristotelian view)", "remediation": "Emphasize Newton's First Law and inertia; relate to everyday examples like sliding on ice"},
    {"concept_id": "electrostatics", "misconception": "Students confuse electric field and electric potential; think field is zero where potential is zero", "remediation": "Use equipotential surface diagrams; practice differentiating E = -dV/dr"},
    {"concept_id": "chemical-bonding", "misconception": "Students think ionic bonds are always stronger than covalent bonds", "remediation": "Compare bond energies; explain lattice energy vs bond dissociation energy"},
    {"concept_id": "thermochemistry", "misconception": "Students confuse exothermic with spontaneous; think all exothermic reactions occur naturally", "remediation": "Introduce Gibbs free energy; distinguish between enthalpy and spontaneity"},
    {"concept_id": "integration", "misconception": "Students forget the constant of integration; think definite integral equals antiderivative at upper limit only", "remediation": "Practice problems emphasizing the +C; use definite integrals with substitution"},
    {"concept_id": "probability", "misconception": "Students apply P(A∪B)=P(A)+P(B) without checking for mutual exclusivity", "remediation": "Use Venn diagrams; practice identifying overlapping events"},
    {"concept_id": "current-electricity", "misconception": "Students think current is 'used up' as it flows through a circuit", "remediation": "Use water analogy; emphasize conservation of charge in series circuits"},
    {"concept_id": "equilibrium", "misconception": "Students think equilibrium constant K changes with concentration or pressure changes", "remediation": "Explain that only temperature affects K; use Le Chatelier's principle correctly"}
  ]
}
